generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String     @id @default(cuid())
  apodo     String     @unique
  createdAt DateTime   @default(now())
  progresos Progreso[]
}

model Juego {
  id          String     @id @default(cuid())
  nombre      String   @unique
  lobulo      String
  lobuloImg   String
  descripcion String
  pdfUrl      String
  progresos   Progreso[]
}

model Progreso {
  id            String    @id @default(cuid())
  userId        String
  juegoId       String
  completadoAt  DateTime?
  syncToken     String?
  syncExpiresAt DateTime?
  user          User      @relation(fields: [userId], references: [id])
  juego         Juego     @relation(fields: [juegoId], references: [id])

  @@unique([userId, juegoId])
}
